# AI Workspace Configuration
# Copy to .env and customize

# Database (PostgreSQL)
AIW_DB_URL=postgresql:///ai_workspace

# Ollama (local models)
OLLAMA_HOST=http://localhost:11434

# DeepSeek API (cloud fallback)
# DEEPSEEK_API_KEY=sk-...

# Kimi API (cloud fallback, moonshot search)
# KIMI_API_KEY=...

# Obsidian vault path
# AIW_OBSIDIAN_VAULT=~/Documents/Obsidian

# Prefect
# PREFECT_HOME=~/.ai-workspace/prefect

# Default models
AIW_DEFAULT_MODEL=qwen3:14b
AIW_DEEP_MODEL=deepseek-r1:14b
AIW_CODER_MODEL=qwen3-coder:30b
