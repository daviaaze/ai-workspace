# Fix numpy/crewAI on NixOS: libstdc++.so.6 is not in default LD path
if [[ -d /nix/store ]]; then
    GCC_LIB=$(echo /nix/store/*-gcc-*-lib/lib 2>/dev/null | head -1)
    ZLIB_LIB=$(echo /nix/store/*-zlib-*/lib 2>/dev/null | head -1)
    export LD_LIBRARY_PATH="${GCC_LIB}${ZLIB_LIB:+:${ZLIB_LIB}}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

# AI Workspace RAG database
export AIW_DATABASE_URL="postgresql://localhost:5439/aiw_rag?host=/tmp/aiw-pg"
