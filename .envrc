# NixOS: pip-installed binary wheels (numpy, etc.) need libstdc++.so.6.
# home-manager sets this globally (see cli.nix), but this acts as a
# fallback for sessions before the next rebuild.
if [[ -d /nix/store ]] && [[ ":$LD_LIBRARY_PATH:" != *"gcc-"*"-lib/lib"* ]]; then
    GCC_LIB=$(nix eval --raw nixpkgs#stdenv.cc.cc.lib 2>/dev/null)
    ZLIB_DIR=$(nix eval --raw nixpkgs#zlib 2>/dev/null)
    [[ -n "$GCC_LIB" ]] && export LD_LIBRARY_PATH="${GCC_LIB}/lib${ZLIB_DIR:+:${ZLIB_DIR}/lib}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi

# AI Workspace RAG database
export AIW_DATABASE_URL="postgresql://localhost:5439/aiw_rag?host=/tmp/aiw-pg"
export AIW_TEST_DB_URL="postgresql://localhost:5439/aiw_rag?host=/tmp/aiw-pg"

# NixOS playwright: point to nix store Node.js and Chromium
if [[ -d /nix/store ]]; then
    NODE_BIN=$(ls -d /nix/store/*-nodejs-*/bin 2>/dev/null | grep -v -- '-dev' | head -1)
    CHROMIUM_PATH=$(ls -d /nix/store/*-chromium-*/. 2>/dev/null | grep -v -- '-dev' | head -1)
    [[ -n "$NODE_BIN" ]] && export PLAYWRIGHT_NODEJS_PATH="$NODE_BIN/node"
    [[ -n "$CHROMIUM_PATH" ]] && export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="$CHROMIUM_PATH/bin/chromium" 2>/dev/null
fi
