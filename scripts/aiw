#!/usr/bin/env bash
# AI Workspace launcher — sets up NixOS library paths transparently.
# Usage: scripts/aiw <command> [args...]
#        scripts/aiw research "query" --depth 2
#
# Without this wrapper, numpy/psycopg2 fail on NixOS because
# libstdc++.so.6 and libz.so.1 are not in the default linker path.

set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"

# Find GCC and zlib store paths (exclude -dev, -static variants)
GCC_LIB=$(ls -d /nix/store/*-gcc-*-lib/lib 2>/dev/null | grep -v -- '-dev\|-static' | head -1)
ZLIB_LIB=$(ls -d /nix/store/*-zlib-*/lib/libz.so 2>/dev/null | grep -v -- '-dev\|-static' | head -1 | xargs dirname)

export LD_LIBRARY_PATH="${GCC_LIB}${ZLIB_LIB:+:${ZLIB_LIB}}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export PYTHONPATH="${ROOT}/src${PYTHONPATH:+:$PYTHONPATH}"
export AIW_DATABASE_URL="${AIW_DATABASE_URL:-postgresql://localhost:5439/aiw_rag?host=/tmp/aiw-pg}"

exec "${ROOT}/.venv/bin/python" -m ai_workspace.cli "$@"
